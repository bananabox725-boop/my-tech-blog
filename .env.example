# ============================================================
# Vercel KV (Redis) — Vercel 대시보드에서 KV 스토어 연결 후 자동 설정
# 로컬 개발: `vercel env pull .env.local` 로 가져오기
# ============================================================
KV_REST_API_URL=https://your-kv-store.upstash.io
KV_REST_API_TOKEN=your_token_here
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token_here

# ============================================================
# 앱 설정
# ============================================================

# 관리자 기본 비밀번호 (미설정 시 fallback: admin123)
# Vercel 대시보드 → Settings → Environment Variables 에서 설정
ADMIN_DEFAULT_PASSWORD=your_secure_password_here

# CORS 허용 도메인 (운영환경에서는 실제 도메인으로 제한)
# 예: https://my-tech-blog.vercel.app
ALLOWED_ORIGIN=*
